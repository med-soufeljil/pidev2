<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ApplicationFormController"
      stylesheets="@style.css"
      alignment="TOP_LEFT"
      styleClass="content-area" style="-fx-padding:20;">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Retour aux applications" fx:id="btnBack"/>
        <Label fx:id="pageTitle" text="Application" styleClass="title-label"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Changer statut:" styleClass="section-label"/>
        <Button text="Nouveau" fx:id="btnTagNouveau" styleClass="status-tag"/>
        <Button text="Premier entretien" fx:id="btnTagPremier" styleClass="status-tag"/>
        <Button text="Deuxième entretien" fx:id="btnTagDeuxieme" styleClass="status-tag"/>
        <Button text="Offre envoyée" fx:id="btnTagOffre" styleClass="status-tag"/>
        <Button text="Acceptée" fx:id="btnTagAcceptee" styleClass="status-tag"/>
        <Button text="Rejetée" fx:id="btnTagRejetee" styleClass="status-tag"/>
    </HBox>

    <GridPane hgap="8" vgap="8" styleClass="form-grid">
        <Label text="Offre d'emploi" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboOffre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Nom" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="formNom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Prénom" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="formPrenom" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="CIN" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="formCin" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Téléphone" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="formTel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
        <Label text="Adresse" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="formAdresse" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
        <Label text="Email" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="formEmail" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        <Label text="CV" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="formCv" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
        <Label text="Statut" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <ComboBox fx:id="formStatus" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
        <Label text="Réunion" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <Label fx:id="lblReunionInfo" text="Aucune réunion planifiée" GridPane.rowIndex="9" GridPane.columnIndex="1" wrapText="true"/>
        <Label text="Réponse offre" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <Label fx:id="lblOfferResponse" text="-" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" fx:id="reunionActions">
        <Button fx:id="btnGenerateReunion" text="Générer réunion"/>
        <Button fx:id="btnSendOffer" text="Générer offre & Envoyer"/>
        <TextField fx:id="salaryField" promptText="Salaire" prefWidth="120"/>
        <Button fx:id="btnSave" text="Enregistrer"/>
    </HBox>
</VBox>
