<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.event.RecommandationController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <!-- Bouton retour en haut -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="retourButton" text="← Retour aux événements"
                style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;" />
    </HBox>

    <!-- Titre principal -->
    <Label text="🔥 Recommandations personnalisées">
        <font>
            <Font name="System Bold" size="28" />
        </font>
    </Label>

    <!-- Sous-titre -->
    <Label text="Découvrez les événements recommandés pour vous basés sur vos centres d'intérêt"
           style="-fx-text-fill: #666666; -fx-font-size: 14px;" wrapText="true" />

    <!-- Barre de filtres -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="typeCombo" prefWidth="200" />
        <Button fx:id="actualiserButton" text="🔄 Actualiser les recommandations"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;" />
    </HBox>

    <!-- Titre de catégorie -->
    <Label fx:id="titreLabel" text="🔥 Événements les plus populaires"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 10 0 0 0;" />

    <!-- Zone des cartes en ligne (FlowPane) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
        <content>
            <FlowPane fx:id="cartesFlowPane" hgap="15" vgap="15" prefWrapLength="1000" style="-fx-padding: 10;" />
        </content>
    </ScrollPane>

    <!-- Indicateur de chargement -->
    <Label fx:id="chargementLabel" text="Chargement en cours..." visible="false"
           style="-fx-font-size: 14px; -fx-text-fill: #666666; -fx-padding: 20;" />
</VBox>