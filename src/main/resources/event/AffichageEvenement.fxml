<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.event.AffichageEvenementController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <!-- En-tête -->
    <Label text="📋 Gestion des Événements (Backoffice)">
        <font>
            <Font name="System Bold" size="24" />
        </font>
    </Label>

    <!-- Barre d'outils avancée -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <!-- Actions CRUD -->
        <Button text="➕ Ajouter" onAction="#handleAjouter"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 5;" />
        <Button text="🔄 Rafraîchir" onAction="#handleRefresh"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 5;" />

        <!-- Menu Export PDF (métier avancé) -->
        <MenuButton text="📄 Export PDF" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;">
            <items>
                <MenuItem text="📋 Export standard" onAction="#handleExportPDFStandard" />
                <MenuItem text="📊 Export statistiques avancé" onAction="#handleExportPDFStatistiques" />
                <MenuItem text="🔍 Export filtré par statut" onAction="#handleExportPDFFiltre" />
            </items>
        </MenuButton>

        <!-- Export Excel (métier avancé) -->
        <Button text="📊 Export Excel avancé" onAction="#handleExportExcel"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 5;" />

        <!-- Export CSV (simple) -->
        <Button text="📄 Export CSV" onAction="#handleExportCSV"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 5;" />

        <!-- Dashboard -->
        <Button text="📊 Dashboard" onAction="#handleDashboard"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 15; -fx-background-radius: 5;" />

        <!-- Recherche -->
        <TextField fx:id="searchField" promptText="Rechercher..." HBox.hgrow="ALWAYS"
                   style="-fx-padding: 8; -fx-background-radius: 5;" />
    </HBox>

    <!-- Tableau des événements -->
    <TableView fx:id="tableEvenements" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="150" />
            <TableColumn fx:id="colDate" text="Date" prefWidth="100" />
            <TableColumn fx:id="colHeureDebut" text="Début" prefWidth="80" />
            <TableColumn fx:id="colHeureFin" text="Fin" prefWidth="80" />
            <TableColumn fx:id="colLieu" text="Lieu" prefWidth="150" />
            <TableColumn fx:id="colPlaces" text="Places" prefWidth="70" />
            <TableColumn fx:id="colInscrits" text="Inscrits" prefWidth="70" />
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
            <TableColumn fx:id="colAction" text="Actions" prefWidth="250" />
        </columns>
    </TableView>
</VBox>