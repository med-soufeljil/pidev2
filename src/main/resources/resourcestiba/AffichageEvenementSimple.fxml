<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.soa.tp1.pi_dev_s2.com.esprit.controllers.AffichageEvenementSimpleController">

    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <!-- En-tête avec titre, recherche et bouton recommandation -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="📋 Découvrez nos événements" textFill="#333333">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <TextField fx:id="searchField" promptText="Rechercher par titre ou lieu..."
                                   HBox.hgrow="ALWAYS" maxWidth="400.0"
                                   style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;" />

                        <!-- Bouton Recommandation en haut -->
                        <Button fx:id="btnRecommandation" text="🔥 Recommandations"
                                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;" />
                        <!-- Dans la barre d'outils, à côté du bouton Recommandation -->
                        <Button text="💬 Assistant IA" onAction="#handleChatbot"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;" />
                    </children>
                </HBox>

                <!-- Liste des événements en cartes -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <FlowPane fx:id="evenementsFlowPane" hgap="20.0" vgap="20.0" prefWrapLength="1000" style="-fx-padding: 10;">
                            <!-- Les cartes seront ajoutées dynamiquement ici -->
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>