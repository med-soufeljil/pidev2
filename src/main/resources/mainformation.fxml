<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1366" prefHeight="768"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.mainformationController"
            stylesheets="@style.css"
            styleClass="content-area">

    <top>
        <VBox spacing="8" styleClass="topbar">
            <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>
            <Label text="Gestion des formations" styleClass="topbar-title"/>
            <Label fx:id="lblRole" styleClass="topbar-subtitle" text="Rôle actuel"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" alignment="CENTER_LEFT">
            <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
            <Label text="Bienvenue dans votre espace" styleClass="welcome-title"/>
            <Label fx:id="lblWelcome" text="Bienvenue" styleClass="welcome-subtitle"/>
            <Label fx:id="lblSuggestion" styleClass="hero-chip" text="Suggestion externe: chargement..."/>

            <HBox spacing="16">
                <VBox spacing="10" styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="Catalogue" styleClass="kpi-label"/>
                    <Button fx:id="btnFormation" text="📘 Gestion Formations" onAction="#openFormation" maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="10" styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="Apprenants" styleClass="kpi-label"/>
                    <Button fx:id="btnApprenant" text="👨‍🎓 Gestion Apprenants" onAction="#openApprenant" maxWidth="1.7976931348623157E308"/>
                </VBox>
                <VBox spacing="10" styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="Analytics" styleClass="kpi-label"/>
                    <Button fx:id="btnDashboard" text="📊 Dashboard" onAction="#openDashboard" maxWidth="1.7976931348623157E308"/>
                </VBox>
            </HBox>

            <VBox spacing="10" styleClass="welcome-panel">
                <Label text="Workflow formation" styleClass="panel-title"/>
                <Label text="✔ Gérer les formations, postulations, feedbacks et reporting." styleClass="panel-item"/>
                <Label text="✔ Accès conditionné selon votre rôle ADMIN/USER." styleClass="panel-item"/>
                <Label text="✔ UI harmonisée avec la gestion de recrutement." styleClass="panel-item"/>
            </VBox>

            <HBox spacing="10">
                <Button text="⬅ Changer espace" onAction="#backToRoleSelection" styleClass="secondary-btn"/>
                <Button text="Quitter" onAction="#quitter" styleClass="danger-btn"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
