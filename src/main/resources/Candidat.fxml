<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.CandidatController"
      stylesheets="@style.css"
      alignment="TOP_CENTER"
      styleClass="content-area" style="-fx-padding:20;">

    <Label text="Gestion des Candidats" styleClass="title-label" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtRecherche" promptText="🔍 Rechercher un candidat..." prefWidth="320"/>
        <Label text="Trier par:"/>
        <ComboBox fx:id="comboTriChamp" promptText="Champ" prefWidth="130"/>
        <ComboBox fx:id="comboTriOrdre" promptText="Ordre" prefWidth="130"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Ajouter" fx:id="btnAjouter"/>
        <Button text="Modifier" fx:id="btnModifier"/>
        <Button text="Supprimer" fx:id="btnSupprimer"/>
        <Button text="Filtre avancé" fx:id="btnFiltre"/>
        <Button text="Reset Filtre" fx:id="btnResetFiltre"/>
        <Label text="Résultats :" styleClass="badge-label"/>
        <Label fx:id="lblCount" text="0" styleClass="badge-count"/>
    </HBox>

    <Label text="Cliquez sur une ligne pour ouvrir le profil candidat" styleClass="hint-label" />

    <TableView fx:id="tableCandidat" prefWidth="1000" prefHeight="480">
        <columns>
            <TableColumn fx:id="colNom" text="Nom"/>
            <TableColumn fx:id="colPrenom" text="Prénom"/>
            <TableColumn fx:id="colCIN" text="CIN"/>
            <TableColumn fx:id="colTel" text="Téléphone"/>
            <TableColumn fx:id="colAdresse" text="Adresse"/>
            <TableColumn fx:id="colEmail" text="Email"/>
            <TableColumn fx:id="colCv" text="CV"/>
        </columns>
    </TableView>

    <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5"/>
</VBox>
