<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.CandidatController"
      stylesheets="@style.css"
      alignment="TOP_LEFT"
      styleClass="content-area" style="-fx-padding:20;">

    <Label text="Gestion des Applications" styleClass="title-label" />

    <HBox spacing="8" alignment="CENTER_LEFT" fx:id="statusTagsBar">
        <Label text="Statuts:" styleClass="section-label"/>
        <Button text="Tous" fx:id="btnTagTous" styleClass="status-tag"/>
        <Button text="Nouveau" fx:id="btnTagNouveau" styleClass="status-tag"/>
        <Button text="Premier entretien" fx:id="btnTagPremier" styleClass="status-tag"/>
        <Button text="Deuxième entretien" fx:id="btnTagDeuxieme" styleClass="status-tag"/>
        <Button text="Offre envoyée" fx:id="btnTagOffre" styleClass="status-tag"/>
        <Button text="Acceptée" fx:id="btnTagAcceptee" styleClass="status-tag"/>
        <Button text="Rejetée" fx:id="btnTagRejetee" styleClass="status-tag"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtRecherche" promptText="🔍 Rechercher une application..." prefWidth="300"/>
        <Label text="Trier par:"/>
        <ComboBox fx:id="comboTriChamp" promptText="Champ" prefWidth="130"/>
        <ComboBox fx:id="comboTriOrdre" promptText="Ordre" prefWidth="120"/>
        <Label text="Grouper par offre:"/>
        <ComboBox fx:id="comboGroupeOffre" prefWidth="190"/>
        <Label text="Résultats :" styleClass="badge-label"/>
        <Label fx:id="lblCount" text="0" styleClass="badge-count"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Nouvelle application" fx:id="btnAjouter"/>
        <Button text="Modifier" fx:id="btnModifier"/>
        <Button text="Supprimer" fx:id="btnSupprimer"/>
        <Button text="Top Fit IA" fx:id="btnTopFit"/>
        <Button text="Reset Filtre" fx:id="btnResetFiltre"/>
    </HBox>

    <TableView fx:id="tableCandidat" prefHeight="420" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOffre" text="Offre" prefWidth="180"/>
            <TableColumn fx:id="colNom" text="Nom"/>
            <TableColumn fx:id="colPrenom" text="Prénom"/>
            <TableColumn fx:id="colCIN" text="CIN"/>
            <TableColumn fx:id="colTel" text="Téléphone"/>
            <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="160"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="170"/>
            <TableColumn fx:id="colCv" text="CV" prefWidth="180"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="130"/>
            <TableColumn fx:id="colAiScore" text="AI Score" prefWidth="85"/>
            <TableColumn fx:id="colAiAnalyse" text="Analyse IA" prefWidth="320"/>
        </columns>
    </TableView>

    <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5"/>


</VBox>
