<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="TOP_LEFT"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ApprenantController"
      stylesheets="@Style.css"
      styleClass="page-root content-area">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestion des Apprenants" styleClass="title-label"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="⬅ Retour" onAction="#retourMain" styleClass="secondary-btn compact-btn"/>
        <TextField fx:id="tfRecherche" promptText="🔍 Rechercher un apprenant..." prefWidth="320"/>
        <Label text="Trier:"/>
        <ComboBox fx:id="cbSortBy" prefWidth="140"/>
        <ComboBox fx:id="cbSortOrder" prefWidth="130"/>
        <Label text="Résultats:" styleClass="badge-label"/>
        <Label fx:id="lblCount" text="0" styleClass="badge-count"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Ajouter" onAction="#ajouter" styleClass="compact-btn"/>
        <Button text="Actualiser" onAction="#actualiser" styleClass="secondary-btn compact-btn"/>
        <Button text="Envoyer mail" onAction="#envoyerMail" styleClass="secondary-btn compact-btn"/>
    </HBox>

    <TableView fx:id="tableApprenant" prefHeight="520" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="130"/>
            <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
            <TableColumn fx:id="colFormation" text="Formation" prefWidth="220"/>
            <TableColumn fx:id="colAction" text="Action" prefWidth="180"/>
        </columns>
    </TableView>
</VBox>
