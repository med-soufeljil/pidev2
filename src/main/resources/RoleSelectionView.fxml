<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18" prefWidth="900" prefHeight="600"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RoleSelectionController"
      stylesheets="@stylef.css" styleClass="page-root">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
    <Label text="Bienvenue" styleClass="hero-title"/>
    <Label text="Choisissez votre espace" styleClass="page-title"/>
    <ComboBox fx:id="cbRole" promptText="Sélectionner un rôle" prefWidth="280"/>
    <Button text="Entrer" onAction="#enterSelectedRole"/>
</VBox>
