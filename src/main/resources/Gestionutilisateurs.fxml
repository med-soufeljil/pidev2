<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.soa.tp1.pi_dev_s2.controller.UtilisateurController"
      style="-fx-background-color:#0F172A;">

    <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:#1E293B;
                 -fx-padding:16 24;
                 -fx-border-color:#334155;
                 -fx-border-width:0 0 1 0;">

        <Label text="👥"  style="-fx-font-size:26px;"/>
        <VBox spacing="2">
            <Label text="Gestion des Utilisateurs"
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#F1F5F9;"/>
            <Label text="CRUD · Recherche · Tri · Réinitialisation MDP · Export CSV"
                   style="-fx-font-size:11px;-fx-text-fill:#64748B;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Badges compteurs -->
        <HBox spacing="10" alignment="CENTER">
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:#1E3A5F;-fx-background-radius:8;-fx-padding:8 14;">
                <Label fx:id="lblTotal" text="0"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#60A5FA;"/>
                <Label text="Total" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:#3B1F1F;-fx-background-radius:8;-fx-padding:8 14;">
                <Label fx:id="lblAdmin" text="0"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#F87171;"/>
                <Label text="Admins" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:#1E3A2F;-fx-background-radius:8;-fx-padding:8 14;">
                <Label fx:id="lblEmploye" text="0"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#34D399;"/>
                <Label text="Employés/RH" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="2"
                  style="-fx-background-color:#1E2A1E;-fx-background-radius:8;-fx-padding:8 14;">
                <Label fx:id="lblUser" text="0"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#A3E635;"/>
                <Label text="Users" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- ══ TOOLBAR ═════════════════════════════════════════════════════ -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-padding:12 24;-fx-background-color:#0F172A;">

        <!-- Recherche -->
        <TextField fx:id="tfRecherche"
                   promptText="🔍  Rechercher par nom, email, rôle…"
                   prefWidth="280"
                   style="-fx-background-color:#1E293B;
                          -fx-text-fill:#E2E8F0;
                          -fx-prompt-text-fill:#475569;
                          -fx-border-color:#334155;
                          -fx-border-radius:8;
                          -fx-background-radius:8;
                          -fx-padding:9 14;
                          -fx-font-size:13px;"/>

        <!-- Filtre rôle -->
        <ComboBox fx:id="cbFiltreRole"
                  prefWidth="130"
                  style="-fx-background-color:#1E293B;
                         -fx-border-color:#334155;
                         -fx-border-radius:8;
                         -fx-background-radius:8;
                         -fx-text-fill:#E2E8F0;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Boutons action -->
        <Button fx:id="btnStats"
                text="📊 Statistiques"
                onAction="#handleToggleStats"
                style="-fx-background-color:#0F2744;
                       -fx-text-fill:#60A5FA;
                       -fx-border-color:#1D4ED8;
                       -fx-border-radius:8;
                       -fx-background-radius:8;
                       -fx-padding:9 16;
                       -fx-cursor:hand;
                       -fx-font-size:12px;"/>

        <Button fx:id="btnExportCSV"
                text="📥 Export CSV"
                onAction="#handleExportCSV"
                style="-fx-background-color:#064E3B;
                       -fx-text-fill:#34D399;
                       -fx-border-color:#065F46;
                       -fx-border-radius:8;
                       -fx-background-radius:8;
                       -fx-padding:9 16;
                       -fx-cursor:hand;
                       -fx-font-size:12px;"/>

        <Button fx:id="btnActualiser"
                text="🔄 Actualiser"
                onAction="#handleActualiser"
                style="-fx-background-color:#1E293B;
                       -fx-text-fill:#94A3B8;
                       -fx-border-color:#334155;
                       -fx-border-radius:8;
                       -fx-background-radius:8;
                       -fx-padding:9 16;
                       -fx-cursor:hand;
                       -fx-font-size:12px;"/>

        <Button fx:id="btnAjouter"
                text="➕  Ajouter"
                onAction="#handleAjouter"
                style="-fx-background-color:#4F46E5;
                       -fx-text-fill:white;
                       -fx-font-weight:bold;
                       -fx-background-radius:8;
                       -fx-padding:9 20;
                       -fx-cursor:hand;
                       -fx-font-size:13px;"/>
    </HBox>

    <!-- ══ PANEL STATS (caché par défaut) ══════════════════════════════ -->
    <VBox fx:id="panelStats"
          spacing="10"
          visible="false"
          managed="false"
          style="-fx-background-color:#0F172A;
                 -fx-border-color:#1E3A8A;
                 -fx-border-width:0 0 1 0;
                 -fx-padding:12 24 16 24;">
    </VBox>

    <!-- ══ TABLE ════════════════════════════════════════════════════════ -->
    <TableView fx:id="tableView"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color:#0F172A;
                      -fx-table-cell-border-color:#1E293B;
                      -fx-control-inner-background:#0F172A;
                      -fx-selection-bar:#1E3A5F;
                      -fx-selection-bar-non-focused:#1E293B;">
        <columns>
            <!-- ID -->
            <TableColumn fx:id="colId"    text="ID"      prefWidth="55"
                         style="-fx-alignment:CENTER;"/>
            <!-- Nom -->
            <TableColumn fx:id="colNom"   text="Nom ↕"   prefWidth="130"/>
            <!-- Prénom -->
            <TableColumn fx:id="colPrenom" text="Prénom ↕" prefWidth="130"/>
            <!-- Email -->
            <TableColumn fx:id="colEmail" text="Email"   prefWidth="220"/>
            <!-- Rôle -->
            <TableColumn fx:id="colRole"  text="Rôle ↕"  prefWidth="110"
                         style="-fx-alignment:CENTER;"/>
            <!-- Actions -->
            <TableColumn fx:id="colActions" text="Actions" prefWidth="170"
                         style="-fx-alignment:CENTER;" sortable="false"/>
        </columns>

        <placeholder>
            <Label text="Aucun utilisateur trouvé."
                   style="-fx-text-fill:#475569;-fx-font-size:14px;"/>
        </placeholder>
    </TableView>

    <!-- ══ FOOTER ══════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="8"
          style="-fx-background-color:#1E293B;
                 -fx-padding:8 24;
                 -fx-border-color:#334155;
                 -fx-border-width:1 0 0 0;">
        <Label text="💡"  style="-fx-font-size:12px;"/>
        <Label text="Clique sur l'en-tête d'une colonne pour trier  ·  🔑 = Réinitialiser mot de passe  ·  ✏ = Modifier  ·  🗑 = Supprimer"
               style="-fx-text-fill:#475569;-fx-font-size:11px;"/>
    </HBox>
</VBox>
