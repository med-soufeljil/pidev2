<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.soa.tp1.pi_dev_s2.mouhamd.controllers.MainController"
            fx:id="rootPane"
            stylesheets="@style.css"
            prefHeight="900"
            prefWidth="1400"
            styleClass="page-root main-root" id="rootPane">

    <left>
        <VBox spacing="20" styleClass="sidebar" prefWidth="300">
            <padding>
                <Insets top="28" right="20" bottom="28" left="20"/>
            </padding>

            <VBox spacing="6" styleClass="brand-box">
                <Label text="TalentFlow" styleClass="brand-title"/>
                <Label text="Recruitment Management Suite" styleClass="brand-subtitle"/>
            </VBox>

            <Label text="Navigation" styleClass="section-label"/>

            <Button text="📊 Dashboard" fx:id="btnDashboard" onAction="#openDashboard" styleClass="sidebar-btn" maxWidth="1.7976931348623157E308"/>
            <Button text="📘 Formations" fx:id="btnFormation" onAction="#openFormation" styleClass="sidebar-btn" maxWidth="1.7976931348623157E308"/>
            <Button text="👨‍🎓 Apprenants" fx:id="btnApprenant" onAction="#openApprenant" styleClass="sidebar-btn" maxWidth="1.7976931348623157E308"/>
            <Button text="⬅ Changer espace" onAction="#backToRoleSelection" styleClass="sidebar-btn secondary-btn" maxWidth="1.7976931348623157E308"/>
            <Button text="Quitter" onAction="#quitter" styleClass="sidebar-btn danger-btn" maxWidth="1.7976931348623157E308"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox spacing="4" styleClass="status-card">
                <Label text="System status" styleClass="status-title"/>
                <Label text="● Connected to training database" styleClass="status-ok"/>
                <Label fx:id="lblRole" text="Rôle actuel: -" styleClass="mode-label"/>
            </VBox>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="topbar">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>

            <VBox spacing="2">
                <Label text="Recruitment Operations Dashboard" styleClass="topbar-title"/>
                <Label text="Track learners, formations and feedbacks in one place" styleClass="topbar-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Dark mode" styleClass="mode-label"/>
            <ToggleButton fx:id="toggleDarkMode" onAction="#toggleDarkMode" styleClass="switch-toggle"/>
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area">
            <VBox fx:id="welcomePane" alignment="TOP_LEFT" spacing="18"
                  AnchorPane.topAnchor="20" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

                <Label text="Welcome back 👋" styleClass="welcome-title"/>
                <Label fx:id="lblWelcome" text="Bienvenue" styleClass="welcome-subtitle"/>
                <Label fx:id="lblSuggestion" text="Suggestion externe: chargement..." styleClass="hero-chip"/>

                <HBox spacing="16">
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                        <Label text="Formation Catalog" styleClass="kpi-label"/>
                        <Label text="Manage programs and levels" styleClass="kpi-value"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                        <Label text="Learner Management" styleClass="kpi-label"/>
                        <Label text="Track status and applications" styleClass="kpi-value"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                        <Label text="Insights" styleClass="kpi-label"/>
                        <Label text="Feedback and KPI monitoring" styleClass="kpi-value"/>
                    </VBox>
                </HBox>

                <VBox spacing="10" styleClass="welcome-panel">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    <Label text="Recommended workflow" styleClass="panel-title"/>
                    <Label text="1. Create or review formations." styleClass="panel-item"/>
                    <Label text="2. Receive postulations from users." styleClass="panel-item"/>
                    <Label text="3. Follow feedbacks and dashboard KPIs." styleClass="panel-item"/>
                </VBox>
            </VBox>
        </AnchorPane>
    </center>

</BorderPane>
