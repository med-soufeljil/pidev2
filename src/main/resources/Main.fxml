<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1366" prefHeight="768"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MainController"
            stylesheets="@Style.css"
            styleClass="page-root">

    <top>
        <VBox spacing="10" styleClass="hero">
            <padding><Insets top="28" right="30" bottom="24" left="30"/></padding>
            <Label text="Système de Gestion des Formations" styleClass="hero-title"/>
            <Label text="Choisissez votre espace d'accès puis ouvrez le module souhaité." styleClass="hero-subtitle"/>
            <Label fx:id="lblSuggestion" styleClass="hero-chip" text="Suggestion externe: chargement..."/>
            <Label fx:id="lblRole" styleClass="hero-chip" text="Rôle actuel: non défini"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="14" alignment="CENTER">
            <padding><Insets top="20" right="26" bottom="22" left="26"/></padding>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Entrer comme ADMIN" onAction="#selectAdmin"/>
                <Button text="Entrer comme USER" onAction="#selectUser" styleClass="secondary-btn"/>
            </HBox>

            <HBox spacing="18" alignment="CENTER">
                <VBox spacing="10" styleClass="feature-card" prefWidth="280">
                    <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>
                    <Label text="📘 Formations" styleClass="section-title"/>
                    <Label wrapText="true" text="ADMIN: gestion complète. USER: consultation + postuler + feedback."/>
                    <Button text="Ouvrir module" onAction="#openFormation"/>
                </VBox>

                <VBox spacing="10" styleClass="feature-card" prefWidth="280">
                    <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>
                    <Label text="👨‍🎓 Apprenants" styleClass="section-title"/>
                    <Label wrapText="true" text="Module réservé à l'ADMIN."/>
                    <Button text="Ouvrir module" onAction="#openApprenant"/>
                </VBox>

                <VBox spacing="10" styleClass="feature-card" prefWidth="280">
                    <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>
                    <Label text="📊 Dashboard" styleClass="section-title"/>
                    <Label wrapText="true" text="Module réservé à l'ADMIN."/>
                    <Button text="Ouvrir module" onAction="#openDashboard"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="bottom-actions">
            <padding><Insets top="8" right="26" bottom="18" left="26"/></padding>
            <Button text="Quitter" onAction="#quitter" styleClass="danger-btn"/>
        </HBox>
    </bottom>
</BorderPane>
