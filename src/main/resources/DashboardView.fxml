<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="1366" prefHeight="768" spacing="14" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.DashboardController" stylesheets="@Style.css" styleClass="page-root">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Dashboard décisionnel" styleClass="page-title"/>
    <Label text="Le PDF est exporté via l'API /api/dashboard/pdf"/>

    <GridPane hgap="10" vgap="10" styleClass="card">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
        <Label text="Formations" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="lblTotalFormations" styleClass="kpi-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Apprenants" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="lblTotalApprenants" styleClass="kpi-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Durée moyenne" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="lblAvgDuree" styleClass="kpi-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Formations certifiées" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="lblCertif" styleClass="kpi-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        <Label text="Top markets (tech)" styleClass="section-title"/>
        <TextField fx:id="tfTech" promptText="java / spring / react ..." prefWidth="280"/>
        <Button text="Trouver Top 3" onAction="#findTopMarkets"/>
    </HBox>

    <ListView fx:id="listMarkets" prefHeight="120" styleClass="card"/>

    <PieChart fx:id="pieChart" title="Répartition certifications" prefHeight="260"/>

    <HBox spacing="10">
        <Button text="Actualiser" onAction="#refresh"/>
        <Button text="Export PDF (API)" onAction="#exportPdf"/>
        <Button text="Export CSV" onAction="#exportCsv" styleClass="secondary-btn"/>
        <Button text="Retour" onAction="#retourMain" styleClass="danger-btn"/>
    </HBox>
</VBox>
