<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.soa.tp1.pi_dev_s2.controller.DashboardController"
        prefWidth="1150" prefHeight="720">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox
                fx:id="sidebar"
                prefWidth="230"
                style="-fx-background-color: #1A237E;">

            <!-- User info -->
            <VBox
                    alignment="CENTER"
                    spacing="6"
                    style="-fx-background-color: #0D1B6E; -fx-padding: 24 16 20 16;">
                <Label
                        text="👤"
                        style="-fx-font-size: 40px;" />
                <Label
                        fx:id="lblUserName"
                        text="Utilisateur"
                        style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <Label
                        fx:id="lblUserRole"
                        text="ROLE"
                        style="-fx-font-size: 11px; -fx-text-fill: #9FA8DA;
                           -fx-background-color: rgba(255,255,255,0.1);
                           -fx-background-radius: 20; -fx-padding: 3 12;" />
            </VBox>

            <!-- Nav buttons — remplis dynamiquement par DashboardController -->
            <!-- (sidebar VBox est fx:id="sidebar") -->

        </VBox>
    </left>

    <!-- ══ ZONE PRINCIPALE ══ -->
    <center>
        <VBox style="-fx-background-color: #F0F4F8;">

            <!-- Topbar -->
            <HBox
                    alignment="CENTER_LEFT"
                    spacing="16"
                    style="-fx-background-color: white;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);
                       -fx-padding: 0 24;
                       -fx-min-height: 58;">
                <Label
                        fx:id="lblPageTitle"
                        text="Tableau de bord"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A237E;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label
                        text="●"
                        style="-fx-text-fill: #43A047; -fx-font-size: 16px;" />
                <Label
                        text="En ligne"
                        style="-fx-text-fill: #888; -fx-font-size: 12px;" />
            </HBox>

            <!-- Contenu dynamique -->
            <ScrollPane
                    VBox.vgrow="ALWAYS"
                    fitToWidth="true"
                    fitToHeight="true"
                    style="-fx-background-color: #F0F4F8;
                       -fx-border-color: transparent;">
                <StackPane
                        fx:id="contentArea"
                        style="-fx-background-color: #F0F4F8; -fx-padding: 24;" />
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
