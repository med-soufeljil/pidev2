{% extends 'base.html.twig' %}
{% block body %}
<h2>Candidats</h2>
<a class="btn" href="{{ path('app_candidat_new') }}">Nouveau candidat</a>
<table>
<thead><tr><th>Nom</th><th>Prénom</th><th>Email</th><th>Statut</th><th>Score IA</th></tr></thead>
<tbody>
{% for item in items %}
<tr><td>{{ item.nom }}</td><td>{{ item.prenom }}</td><td>{{ item.email }}</td><td>{{ item.statut }}</td><td>{{ item.aiScore }}</td></tr>
{% else %}<tr><td colspan="5">Aucun candidat</td></tr>{% endfor %}
</tbody>
</table>
{% endblock %}
