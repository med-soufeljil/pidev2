{% extends 'base.html.twig' %}
{% block body %}
<h2>Réunions</h2>
<a class="btn" href="{{ path('app_reunion_new') }}">Nouvelle réunion</a>
<table>
<thead><tr><th>Candidat</th><th>Date</th><th>Lien</th><th>Actions</th></tr></thead>
<tbody>
{% for item in items %}
<tr>
<td>{{ item.candidat.nom }} {{ item.candidat.prenom }}</td><td>{{ item.date|date('Y-m-d H:i') }}</td><td>{{ item.link }}</td>
<td>
  <a class="btn" href="{{ path('app_reunion_edit', {id: item.id}) }}">Modifier</a>
  <form method="post" action="{{ path('app_reunion_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_reunion_' ~ item.id) }}">
    <button class="btn btn-danger">Supprimer</button>
  </form>
</td>
</tr>
{% else %}<tr><td colspan="4">Aucune réunion</td></tr>{% endfor %}
</tbody>
</table>
{% endblock %}
