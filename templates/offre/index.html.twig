{% extends 'base.html.twig' %}
{% block body %}
<h2>Offres</h2>
<a class="btn" href="{{ path('app_offre_new') }}">Nouvelle offre</a>
<table>
<thead><tr><th>Nom</th><th>Type</th><th>Compétences</th><th>Salaire</th><th>Actions</th></tr></thead>
<tbody>
{% for item in items %}
<tr>
<td>{{ item.nomOffre }}</td><td>{{ item.type.value }}</td><td>{{ item.competences }}</td><td>{{ item.salaire }}</td>
<td>
  <a class="btn" href="{{ path('app_offre_edit', {id: item.id}) }}">Modifier</a>
  <form method="post" action="{{ path('app_offre_delete', {id: item.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer ?')">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_offre_' ~ item.id) }}">
    <button class="btn btn-danger">Supprimer</button>
  </form>
</td>
</tr>
{% else %}<tr><td colspan="5">Aucune offre</td></tr>{% endfor %}
</tbody>
</table>
{% endblock %}
